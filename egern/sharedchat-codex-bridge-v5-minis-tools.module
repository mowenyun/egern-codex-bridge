sharedchat-codex-bridge-v5-minis-tools = type=http-request,pattern=^https?://new\.sharedchat\.cc/(v1/(responses|chat/completions)|codex/responses)(\?.*)?$,requires-body=true,script-path=https://raw.githubusercontent.com/mowenyun/egern-codex-bridge/main/egern/sharedchat-codex-bridge-v5-minis-tools.js

[MITM]
hostname = new.sharedchat.cc
