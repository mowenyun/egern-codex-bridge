#!icon=https://raw.githubusercontent.com/Koolson/Qure/master/IconSet/Color/AISet.png

[Script]
any-unified = type=http-request,pattern=^https?://(a-ocnfniawgw\.cn-shanghai\.fcapp\.run|anyrouter\.top)/v1/(responses|messages|models|chat/completions)(\?.*)?$,requires-body=false,script-path=https://raw.githubusercontent.com/mowenyun/egern-codex-bridge/main/egern/any/any.js

[MITM]
hostname = a-ocnfniawgw.cn-shanghai.fcapp.run, anyrouter.top
