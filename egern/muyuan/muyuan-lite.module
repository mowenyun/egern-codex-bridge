#!name=Codex TUI Spoof Lite
#!desc=轻量伪装 Minis/iOS 请求为 Codex TUI 0.141.0；不注入 session-id/thread-id/x-client-request-id/x-codex-turn-metadata 等动态会话指纹。
#!author=星
#!homepage=https://muyuan.do
#!icon=https://raw.githubusercontent.com/Koolson/Qure/master/IconSet/Color/OpenAI.png

[Rewrite]
# ===== Muyuan: https://muyuan.do/v1/* =====
# 删除 Minis / iOS / 浏览器特征
^https?://muyuan\.do/v1/ header-del User-Agent
^https?://muyuan\.do/v1/ header-del user-agent
^https?://muyuan\.do/v1/ header-del Accept
^https?://muyuan\.do/v1/ header-del accept
^https?://muyuan\.do/v1/ header-del Accept-Language
^https?://muyuan\.do/v1/ header-del accept-language
^https?://muyuan\.do/v1/ header-del Priority
^https?://muyuan\.do/v1/ header-del priority
^https?://muyuan\.do/v1/ header-del Origin
^https?://muyuan\.do/v1/ header-del origin
^https?://muyuan\.do/v1/ header-del Referer
^https?://muyuan\.do/v1/ header-del referer

# 如果站点依赖 WAF Cookie，可先不删 Cookie；如仍被识别，再尝试删除 Cookie
# ^https?://muyuan\.do/v1/ header-del Cookie
# ^https?://muyuan\.do/v1/ header-del cookie

# Codex TUI 基础指纹，不注入动态会话ID
^https?://muyuan\.do/v1/ header-add Accept "text/event-stream"
^https?://muyuan\.do/v1/ header-add User-Agent "codex-tui/0.141.0 (Ubuntu 24.4.0; aarch64) xterm-256color (codex-tui; 0.141.0)"
^https?://muyuan\.do/v1/ header-add originator "codex-tui"
^https?://muyuan\.do/v1/ header-add x-codex-beta-features "remote_compaction_v2"

# ===== Any / fcapp.run: https://*.fcapp.run/v1/* =====
# 删除 Minis / iOS / 浏览器特征
^https?://.*\.fcapp\.run/v1/ header-del User-Agent
^https?://.*\.fcapp\.run/v1/ header-del user-agent
^https?://.*\.fcapp\.run/v1/ header-del Accept
^https?://.*\.fcapp\.run/v1/ header-del accept
^https?://.*\.fcapp\.run/v1/ header-del Accept-Language
^https?://.*\.fcapp\.run/v1/ header-del accept-language
^https?://.*\.fcapp\.run/v1/ header-del Priority
^https?://.*\.fcapp\.run/v1/ header-del priority
^https?://.*\.fcapp\.run/v1/ header-del Origin
^https?://.*\.fcapp\.run/v1/ header-del origin
^https?://.*\.fcapp\.run/v1/ header-del Referer
^https?://.*\.fcapp\.run/v1/ header-del referer

# fcapp/Any 有时需要 WAF Cookie，先保留 Cookie
# ^https?://.*\.fcapp\.run/v1/ header-del Cookie
# ^https?://.*\.fcapp\.run/v1/ header-del cookie

# Codex TUI 基础指纹，不注入动态会话ID
^https?://.*\.fcapp\.run/v1/ header-add Accept "text/event-stream"
^https?://.*\.fcapp\.run/v1/ header-add User-Agent "codex-tui/0.141.0 (Ubuntu 24.4.0; aarch64) xterm-256color (codex-tui; 0.141.0)"
^https?://.*\.fcapp\.run/v1/ header-add originator "codex-tui"
^https?://.*\.fcapp\.run/v1/ header-add x-codex-beta-features "remote_compaction_v2"

[MITM]
hostname = muyuan.do, *.fcapp.run, a-ocnfniawgw.cn-shanghai.fcapp.run
