#!name=SharedChat Codex Bridge
#!desc=SharedChat Codex 专用桥接：只处理 /v1/responses、/v1/chat/completions、/codex/responses；不碰 /v1/messages 与 /v1/models，便于与同站点 Claude 模块共存。
#!author=星
#!homepage=https://github.com/mowenyun/egern-codex-bridge
#!icon=https://raw.githubusercontent.com/Koolson/Qure/master/IconSet/Color/OpenAI.png

[Script]
sharedchat-codex-bridge = type=http-request,pattern=^https?://new\.sharedchat\.cc/(v1/(responses|chat/completions)|codex/responses)(\?.*)?$,requires-body=true,script-path=https://raw.githubusercontent.com/mowenyun/egern-codex-bridge/main/egern/sharedchat/sharedchat.js

[MITM]
hostname = new.sharedchat.cc
